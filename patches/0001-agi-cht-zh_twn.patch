+	_gfx->drawBig5Character(charCurPos.row, charCurPos.column, big5, _textAttrib.foreground, _textAttrib.background);
+
+	// 640x400 hi-res：字格寬=16px，一個 16x16 中文字佔 1 格
+	charCurPos.column += 1;
+	if (charCurPos.column <= (FONT_COLUMN_CHARACTERS - 1)) {
+		charPos_Set(&charCurPos);
+	} else {
+		displayCharacter(0x0D); // go to next line
+	}
