+// 繁體中文化：計算 [start, start+len) 的顯示欄寬。Big5(0x81-0xFE lead + trail)一個字佔 1 欄（16px 格），
+// 其餘每 byte 1 欄。原本 wrap 用 byte 數當寬度，Big5 每字 2 byte 會被當 2 欄 → 短句過早換行。
+static int16 chtColWidth(const char *t, int16 start, int16 len) {
+	int16 cols = 0, i = start, end = start + len;
+	while (i < end) {
+		byte c = (byte)t[i];
+		if (c >= 0x81 && c <= 0xFE && i + 1 < end) { cols++; i += 2; }
+		else { cols++; i++; }
+	}
+	return cols;
+}
+// 從 start 起累積到 maxCols 顯示欄所需的 byte 長度（不切斷 Big5 字）。
+static int16 chtBytesForCols(const char *t, int16 start, int16 len, int16 maxCols) {
+	int16 cols = 0, i = start, end = start + len;
+	while (i < end && cols < maxCols) {
+		byte c = (byte)t[i];
+		if (c >= 0x81 && c <= 0xFE && i + 1 < end) i += 2; else i++;
+		cols++;
+	}
+	return i - start;
+}
