+// 繁體中文化：把 \n / \\ escape 還原成實際位元組（AGI 訊息含硬換行，塞不進單行 TSV）
+static Common::String chtUnescape(const Common::String &in) {
+	Common::String out;
+	for (uint i = 0; i < in.size(); i++) {
+		if (in[i] == '\\' && i + 1 < in.size()) {
+			char n = in[i + 1];
+			if (n == 'n') { out += '\n'; i++; continue; }
+			if (n == '\\') { out += '\\'; i++; continue; }
+			if (n == 't') { out += '\t'; i++; continue; }
+		}
+		out += in[i];
+	}
+	return out;
+}
+
+// 繁體中文化：載入 Big5 字型與 translation.tsv。須在 initVideo() 之前呼叫（initVideo 依 _chtEnabled 決定拉 hi-res）。
+void GfxMgr::loadChtResources() {
+	// 繁體中文化以「遊戲目錄有無 lsl_big5.fnt」為開關，不依賴 --language。
+	// 原因：LSL1 AGI 在 ScummVM 走 fallback 偵測，一旦把 target 語言設成非英文就無法啟動遊戲
+	//（任何非英文語言皆然，與中文無關）。改用字型檔存在與否，遊戲以英文正常啟動，中文照樣生效。
+	Common::File fontFile;
+	if (!fontFile.open("lsl_big5.fnt")) {
+		_chtEnabled = false;
+		return; // 沒有中文字型 → 維持英文
+	}
+	_chtEnabled = true;
+	_chtFont = new Graphics::Big5Font();
+	_chtFont->loadPrefixedRaw(fontFile, 16);
+	fontFile.close();
+	debug("AGI-CHT: Big5 字型 lsl_big5.fnt 已載入");
+
+	// translation.tsv：<english>\t<big5>，逐行載入成 HashMap
+	Common::File tsvFile;
+	if (tsvFile.open("translation.tsv")) {
+		while (!tsvFile.eos()) {
+			Common::String line = tsvFile.readLine();
+			if (line.empty())
+				continue;
+			uint32 tab = line.findFirstOf('\t');
+			if (tab == Common::String::npos)
+				continue;
+			Common::String key = chtUnescape(line.substr(0, tab));
+			Common::String val = chtUnescape(line.substr(tab + 1));
+			_chtTranslation[key] = val;
+		}
+		tsvFile.close();
+		debug("AGI-CHT: 載入 %d 則翻譯", (int)_chtTranslation.size());
+	} else {
+		warning("AGI-CHT: 找不到 translation.tsv");
+	}
+}
+
+// 用英文原文當 key 查中譯；查無則原樣返回
+const char *GfxMgr::getChtTranslation(const char *english) const {
+	if (!_chtEnabled || !english)
+		return english;
+	Common::HashMap<Common::String, Common::String>::const_iterator it = _chtTranslation.find(Common::String(english));
+	if (it != _chtTranslation.end())
+		return it->_value.c_str();
+	return english;
+}
+
+// 在文字格 (row,column) 畫一個 16x16 中文字
+void GfxMgr::drawBig5Character(int16 row, int16 column, uint16 big5, byte foreground, byte background) {
+	int16 x = column;
+	int16 y = row;
+	translateFontPosToDisplayScreen(x, y); // x=column*16, y=row*16（hi-res）
+	drawBig5CharacterOnDisplay(x, y, big5, foreground, background);
+}
+
+void GfxMgr::drawBig5CharacterOnDisplay(int16 x, int16 y, uint16 big5, byte foreground, byte background) {
+	if (!_chtFont)
+		return;
+	// 先把 16x16 cell 填背景色（Big5Font 只畫前景 pixel，不清底）
+	for (int16 cy = 0; cy < 16; cy++) {
+		byte *rowPtr = _displayScreen + (y + cy) * _displayScreenWidth + x;
+		for (int16 cx = 0; cx < 16; cx++)
+			rowPtr[cx] = background;
+	}
+	byte *dest = _displayScreen + y * _displayScreenWidth + x;
+	_chtFont->drawBig5Char(dest, big5, 16, 16, _displayScreenWidth, foreground, background, false, 1);
+	copyDisplayRectToScreen(x, y, 16, 16); // 中文字固定 16x16（不用 _displayFontWidth，原生模式為 8）
+}
