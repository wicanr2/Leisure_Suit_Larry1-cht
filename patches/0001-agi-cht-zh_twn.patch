+// 繁體中文化：在目前文字格畫一個 16x16 中文字，游標前進一格（換行邏輯同 displayCharacter）
+void TextMgr::displayBig5Character(uint16 big5) {
+	TextPos_Struct charCurPos;
+	charPos_Get(&charCurPos);
+
+	_gfx->drawBig5Character(charCurPos.row, charCurPos.column, big5, _textAttrib.combinedForeground, _textAttrib.combinedBackground);
+
+	// 原生 320x200：一個 16px 中文字佔 2 個 8px 字格
+	charCurPos.column += 2;
+	if (charCurPos.column <= (FONT_COLUMN_CHARACTERS - 1)) {
+		charPos_Set(&charCurPos);
+	} else {
+		displayCharacter(0x0D); // go to next line
+	}
+}
