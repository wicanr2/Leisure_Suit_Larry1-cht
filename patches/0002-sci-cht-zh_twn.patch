+const char *SciEngine::getChtTranslation(const char *original) const {
+	if (_chtTranslation.empty() || !original)
+		return nullptr;
+	Common::HashMap<Common::String, Common::String>::const_iterator it = _chtTranslation.find(original);
+	if (it == _chtTranslation.end())
+		return nullptr;
+	return it->_value.c_str();
+}
+
+static Common::String unescapeCht(const Common::String &in) {
+	Common::String out;
+	for (uint i = 0; i < in.size(); ++i) {
+		if (in[i] == '\\' && i + 1 < in.size()) {
+			char n = in[i + 1];
+			if (n == 'n') { out += '\n'; ++i; continue; }
+			if (n == 't') { out += '\t'; ++i; continue; }
+			if (n == '\\') { out += '\\'; ++i; continue; }
+		}
+		out += in[i];
+	}
+	return out;
+}
+
+void SciEngine::loadChtTranslation() {
+	// Runtime translation file: one entry per line, "<english>\t<big5 bytes>".
+	// TAB (0x09) and LF (0x0A) never occur inside Big5, so they are safe
+	// delimiters. Human-maintained source is UTF-8; the build tool converts it
+	// to this Big5 runtime form. Shipped in the game directory as CHT patch data.
+	Common::File f;
+	if (!f.open("translation.tsv"))
+		return;
+	int count = 0;
+	while (!f.eos()) {
+		Common::String line = f.readLine();
+		if (line.empty())
+			continue;
+		const char *s = line.c_str();
+		const char *tab = strchr(s, '\t');
+		if (!tab || tab == s)
+			continue;
+		Common::String key(s, tab - s);
+		Common::String val(tab + 1);
+		if (val.empty())
+			continue;
+		// Unescape "\\n"->newline and "\\\\"->backslash (SCI0/EGA strings contain
+		// hard line breaks, which cannot sit literally in a line-based TSV).
+		_chtTranslation[unescapeCht(key)] = unescapeCht(val);
+		++count;
+	}
+	debug(1, "CHT: loaded %d translation entries", count);
+}
+
+// 載入標題疊圖 lsl_title.ovl（VGA/SCI，含內嵌調色盤）。格式見 tools/build_title_overlay.py。
+void SciEngine::loadChtTitleOverlay() {
+	Common::File f;
+	if (!f.open("lsl_title.ovl"))
+		return;
+	byte magic[4];
+	f.read(magic, 4);
+	if (memcmp(magic, "CHTO", 4) != 0)
+		return;
+	f.readByte();                 // version
+	byte palType = f.readByte();
+	_chtTitleOX = f.readUint16BE();
+	_chtTitleOY = f.readUint16BE();
+	_chtTitleOW = f.readUint16BE();
+	_chtTitleOH = f.readUint16BE();
+	if (palType != 1) {           // SCI 端只吃內嵌調色盤格式(VGA)
+		return;
+	}
+	_chtTitleNumColors = f.readByte();
+	for (int i = 0; i < _chtTitleNumColors; i++) {
+		_chtTitlePalR[i] = f.readByte();
+		_chtTitlePalG[i] = f.readByte();
+		_chtTitlePalB[i] = f.readByte();
+	}
+	uint32 n = (uint32)_chtTitleOW * _chtTitleOH;
+	_chtTitleOverlay = (byte *)malloc(n);
+	if (!_chtTitleOverlay) { _chtTitleOW = _chtTitleOH = 0; return; }
+	f.read(_chtTitleOverlay, n);
+	debug(1, "CHT: 標題疊圖已載入 (%dx%d @ %d,%d, %d 色)",
+	      _chtTitleOW, _chtTitleOH, _chtTitleOX, _chtTitleOY, _chtTitleNumColors);
+}
+
+// 把「幻想空間」中文標題疊到當前 display 上。內嵌調色盤 nearest-map 到當前遊戲 palette，
+// 直接寫 display buffer(640x400 upscaled 座標)後全螢幕 present。由 text16 偵測到標題/警告字時觸發。
+void SciEngine::drawChtTitleOverlay() {
+	if (!_chtTitleOverlay || !_gfxScreen || !_gfxPalette16)
+		return;
+	if (_gfxScreen->getDisplayWidth() < _chtTitleOX + _chtTitleOW ||
+	    _gfxScreen->getDisplayHeight() < _chtTitleOY + _chtTitleOH)
+		return; // 非 upscaled(640x400) 或尺寸不符,不疊避免越界
+
+	// 內嵌調色盤 → 當前 palette 最近色索引(只在 used 色間找)
+	byte remap[256];
+	const Palette &sp = _gfxPalette16->_sysPalette;
+	for (int i = 0; i < _chtTitleNumColors; i++) {
+		int best = 1 << 30, bi = 0;
+		for (int j = 0; j < 256; j++) {
+			if (!sp.colors[j].used)
+				continue;
+			int dr = (int)sp.colors[j].r - _chtTitlePalR[i];
+			int dg = (int)sp.colors[j].g - _chtTitlePalG[i];
+			int db = (int)sp.colors[j].b - _chtTitlePalB[i];
+			int d = dr*dr + dg*dg + db*db;
+			if (d < best) { best = d; bi = j; }
+		}
+		remap[i] = (byte)bi;
+	}
+
+	for (uint16 ry = 0; ry < _chtTitleOH; ry++) {
+		const byte *src = _chtTitleOverlay + ry * _chtTitleOW;
+		for (uint16 rx = 0; rx < _chtTitleOW; rx++) {
+			byte v = src[rx];
+			if (v == 0xFF || v >= _chtTitleNumColors)
+				continue;
+			_gfxScreen->putPixelOnDisplay(_chtTitleOX + rx, _chtTitleOY + ry, remap[v]);
+		}
+	}
+	_gfxScreen->copyToScreen();
+	_chtTitleDrawn = true;
+}
+
 Common::Language SciEngine::getLanguage() const {
+	// Traditional Chinese fan translation: allow forcing ZH_TWN via the target's
+	// "language" config key (e.g. --language=zh_TW) so the CHT patch can be applied
+	// on top of the original English game without a dedicated detection entry.
+	if (ConfMan.hasKey("language")) {
+		if (Common::parseLanguage(ConfMan.get("language")) == Common::ZH_TWN)
+			return Common::ZH_TWN;
+	}
 	return _gameDescription->language;
 }
 
