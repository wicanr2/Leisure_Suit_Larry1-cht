+	Script *scr = _gamestate->_segMan->getScriptIfLoaded(seg);
+	if (!scr || !scr->getLocalsBegin() || idx < 0 || idx >= (int)scr->getLocalsCount())
+		return -32768;
+	return (int16)scr->getLocalsBegin()[idx].getOffset();
+}
+
+// 啟動時：若已有存檔（玩家先前必已通過驗證），或存在 .chtok 旗標檔，即視為已驗證。
+void SciEngine::chtLoadVerifiedState() {
+	if (getLanguage() != Common::ZH_TWN)
+		return;
+	Common::SaveFileManager *sfm = g_system->getSavefileManager();
+	// 條件一：任何存檔存在（LSL1 SCI 存檔名 <target>.### 或 <target>.sav 系列）。
+	if (!sfm->listSavefiles(_targetName + ".###").empty() ||
+	    !sfm->listSavefiles(_targetName + ".s##").empty() ||
+	    !sfm->listSavefiles(_targetName + ".0##").empty()) {
+		_chtVerified = true;
+	}
+	// 條件二：先前已寫過通過旗標。
+	if (!sfm->listSavefiles(_targetName + ".chtok").empty())
+		_chtVerified = true;
+	if (_chtVerified)
+		debug(1, "CHT: age-verify auto-answer ENABLED (save or flag present)");
+}
+
+// 寫通過旗標檔（冪等；openForSaving 會覆蓋）。之後即使刪存檔也免重答。
+void SciEngine::chtMarkVerified() {
+	_chtVerified = true;
+	Common::SaveFileManager *sfm = g_system->getSavefileManager();
+	Common::WriteStream *ws = sfm->openForSaving(_targetName + ".chtok", false);
+	if (ws) {
+		ws->writeString("ok\n");
+		ws->finalize();
+		delete ws;
+	}
+	debug(1, "CHT: age-verify passed → wrote .chtok flag");
+}
+
+// 事件層取用：回傳下一個待注入的合成鍵（TAB/ENTER），佇列空回 0。
+int SciEngine::chtVerifyPendingKey() {
+	if (_chtVerifyKeyHead >= _chtVerifyKeyTail) {
+		_chtVerifyKeyHead = _chtVerifyKeyTail = 0;
+		return 0;
+	}
+	return _chtVerifyKeyQueue[_chtVerifyKeyHead++];
+}
+
+// 每輪：追蹤 room 720 進出。曾進入 720 後又離開 = 通過驗證（不論本次是自動或手動作答）→
+// 寫旗標，讓「首次手動通過」的玩家下次啟動也自動作答。
+void SciEngine::chtVerifyRoomTick() {
+	if (getLanguage() != Common::ZH_TWN || _chtVerifyDone || !_gamestate)
+		return;
+	uint16 room = _gamestate->currentRoomNumber();
+	if (room == 720) {
+		_chtVerifyWasIn720 = true;
+	} else if (room != 0 && _chtVerifyWasIn720) {
+		_chtVerifyDone = true;
+		debug(1, "CHT: left age-verify room 720 → now room %d (verify complete)", room);
+		chtMarkVerified();
+	}
+}
+
+// Box 顯示文字時呼叫：若正在 room 720 且已通過，讀 L4 決定要送出的合成鍵。
+void SciEngine::chtVerifyOnText(const char *text) {
+	if (!_gamestate || !text)
+		return;
+	if (_gamestate->currentRoomNumber() != 720)
+		return;
+	if (!_chtVerified || _chtVerifyDone)
+		return;
+	// 仍有鍵在佇列 → 上一則對話尚未處理完，先別重排（避免對同一對話重複作答）。
+	if (_chtVerifyKeyHead < _chtVerifyKeyTail)
+		return;
+
+	// 年齡選單（6 選項 2×3 格：under 15/16-18/19-39/40-65/66-99/over 100）。
+	// 焦點起於第 1 格「under 15」，TAB 逐格移動；選成人格再 ENTER。目標「40 to 65」（第 4 格），
+	// 即使 TAB 數差一格，鄰格 19-39 / 66-99 仍是成人，容錯較大 → TAB×3 + ENTER。
+	if (strstr(text, "how old are you")) {
+		if (_chtVerifyLastId == 40)   // 已對本次年齡選單作答過
+			return;
+		_chtVerifyLastId = 40;
+		for (int i = 0; i < 3 && _chtVerifyKeyTail < 7; i++)
+			_chtVerifyKeyQueue[_chtVerifyKeyTail++] = kSciKeyTab;
+		_chtVerifyKeyQueue[_chtVerifyKeyTail++] = kSciKeyEnter;
+		debug(1, "CHT: auto age-menu → TAB x3 + ENTER (target 40 to 65)");
+		return;
+	}
+
+	int16 l4 = chtReadVerifyLocal(4);   // 正解編號 1-4（成人問答；即題庫文字首字元）
+	int16 l5 = chtReadVerifyLocal(5);   // 題目序號：換新題時改變，選項/確認/空白畫面維持不變
+
+	if (l4 >= 1 && l4 <= 4) {
+		// 成人問答（a/b/c/d 字母選項）：正解編號存於 local[4]（1→a…4→d），直接按對應字母鍵作答。
+		// 以 L5 變化偵測「新題」：同一題的各選項回顯、確認畫面 L5 不變 → 不重複作答。
+		if (l5 == _chtVerifyLastId)
+			return;
+		_chtVerifyLastId = l5;
+		_chtVerifyKeyQueue[_chtVerifyKeyTail++] = 'a' + (l4 - 1);
+		debug(1, "CHT: auto-answer Q (id=%d) → '%c'", l5, 'a' + (l4 - 1));
+	} else {
+		// L4=0 文字。以文字雜湊去重（同一畫面重繪不重按；不同畫面各自處理）。
+		size_t n = strlen(text);
+		if (n == 0)
+			return;   // 空白過場，不動作
+		uint32 hh = 5381;
+		for (const char *p = text; *p; ++p)
+			hh = hh * 33 + (byte)*p;
+		int16 sig = (int16)(1000 + (hh % 20000));   // 與 L5(<100)、年齡選單標記 40 不相碰
+		if (sig == _chtVerifyLastId)
+			return;
+		if (text[n - 1] == '?') {
+			// 「問句」（結尾 '?'，且已排除年齡選單）＝ 任意答案皆可的笑話題（如「幾個工程師才能換
+			// 一顆燈泡？」），遊戲不設正解（L4=0）→ 按 'a' 即過關。
+			_chtVerifyLastId = sig;
+			_chtVerifyKeyQueue[_chtVerifyKeyTail++] = 'a';
+			debug(1, "CHT: auto-answer joke Q (any answer) → 'a'");
+		}
+		// 其餘 L4=0 非問句文字（片頭/答題間過場/選項回顯）不注入：過場會自行前進、片頭交玩家推進。
+	}
+}
+
+// Ctrl+Alt+X：一鍵略過驗證，直接跳到遊戲開始（room 100）。不逐題模擬作答——驗證場景題型繁多
+// （常識/笑話/手冊防拷），直接跳場最單純可靠。用 ScummVM 除錯器 "room" 指令的同一機制。
+void SciEngine::chtVerifySkipNow() {
+	if (getLanguage() != Common::ZH_TWN || !_gamestate)
+		return;
+	if (_gamestate->currentRoomNumber() != 720)
+		return;   // 僅在年齡驗證室（room 720）生效
+	// 直接把遊戲場景切到 room 100（賴瑞站在老左酒吧外的開場），繞過整個年齡/問答驗證。
+	// 這是 ScummVM 除錯器 "room" 指令用的同一機制（setRoomNumber 寫 newRoom 全域，主迴圈換場）。
+	// 不再逐題模擬作答——驗證場景題型繁多（常識/笑話/手冊防拷），直接跳場最單純可靠。
+	_chtVerified = true;
+	_chtVerifyDone = true;      // 本次啟動不再自動作答（已跳場）
+	chtMarkVerified();          // 寫 .chtok 旗標：之後開機自動略過驗證
+	_gamestate->setRoomNumber(100);
+	// 清掉驗證室殘留的對話框 window（年齡選單等）——沿用 restore 路徑的做法，否則會疊在
+	// room 100 畫面上。reset() 釋放 _picWind 以外所有 window。
+	if (_gfxPorts)
+		_gfxPorts->reset();
+	// 打斷驗證控制項的 VM 等待迴圈：kAbortLoadGame 會 unwind 後呼叫遊戲 replay，進入
+	// currentRoomNumber()（＝剛設的 100）——等同「在年齡選單時載入存檔」的恢復路徑。
+	_gamestate->abortScriptProcessing = kAbortLoadGame;
+	debug(1, "CHT: Ctrl+Alt+X → 直接跳到遊戲開始（room 100），略過驗證");
+}
+
+static Common::String unescapeCht(const Common::String &in) {
+	Common::String out;
+	for (uint i = 0; i < in.size(); ++i) {
+		if (in[i] == '\\' && i + 1 < in.size()) {
+			char n = in[i + 1];
+			if (n == 'n') { out += '\n'; ++i; continue; }
+			if (n == 't') { out += '\t'; ++i; continue; }
+			if (n == '\\') { out += '\\'; ++i; continue; }
+		}
+		out += in[i];
+	}
+	return out;
+}
+
+void SciEngine::loadChtTranslation() {
+	// Runtime translation file: one entry per line, "<english>\t<big5 bytes>".
+	// TAB (0x09) and LF (0x0A) never occur inside Big5, so they are safe
+	// delimiters. Human-maintained source is UTF-8; the build tool converts it
+	// to this Big5 runtime form. Shipped in the game directory as CHT patch data.
+	Common::File f;
+	if (!f.open("translation.tsv"))
+		return;
+	int count = 0;
+	while (!f.eos()) {
+		Common::String line = f.readLine();
+		if (line.empty())
+			continue;
+		const char *s = line.c_str();
+		const char *tab = strchr(s, '\t');
+		if (!tab || tab == s)
+			continue;
+		Common::String key(s, tab - s);
+		Common::String val(tab + 1);
+		if (val.empty())
+			continue;
+		// Unescape "\\n"->newline and "\\\\"->backslash (SCI0/EGA strings contain
+		// hard line breaks, which cannot sit literally in a line-based TSV).
+		_chtTranslation[unescapeCht(key)] = unescapeCht(val);
+		++count;
+	}
+	debug(1, "CHT: loaded %d translation entries", count);
+}
+
+// 載入標題疊圖 lsl_title.ovl（VGA/SCI，含內嵌調色盤）。格式見 tools/build_title_overlay.py。
+void SciEngine::loadChtTitleOverlay() {
+	Common::File f;
+	if (!f.open("lsl_title.ovl"))
+		return;
+	byte magic[4];
+	f.read(magic, 4);
+	if (memcmp(magic, "CHTO", 4) != 0)
+		return;
+	f.readByte();                 // version
+	byte palType = f.readByte();
+	_chtTitleOX = f.readUint16BE();
+	_chtTitleOY = f.readUint16BE();
+	_chtTitleOW = f.readUint16BE();
+	_chtTitleOH = f.readUint16BE();
+	if (palType != 1) {           // SCI 端只吃內嵌調色盤格式(VGA)
+		return;
+	}
+	_chtTitleNumColors = f.readByte();
+	for (int i = 0; i < _chtTitleNumColors; i++) {
+		_chtTitlePalR[i] = f.readByte();
+		_chtTitlePalG[i] = f.readByte();
+		_chtTitlePalB[i] = f.readByte();
+	}
+	uint32 n = (uint32)_chtTitleOW * _chtTitleOH;
+	_chtTitleOverlay = (byte *)malloc(n);
+	if (!_chtTitleOverlay) { _chtTitleOW = _chtTitleOH = 0; return; }
+	f.read(_chtTitleOverlay, n);
+	debug(1, "CHT: 標題疊圖已載入 (%dx%d @ %d,%d, %d 色)",
+	      _chtTitleOW, _chtTitleOH, _chtTitleOX, _chtTitleOY, _chtTitleNumColors);
+}
+
+// 把「幻想空間」中文標題疊到當前 display 上。內嵌調色盤 nearest-map 到當前遊戲 palette，
+// 直接寫 display buffer(640x400 upscaled 座標)後全螢幕 present。由 text16 偵測到標題/警告字時觸發。
+void SciEngine::drawChtTitleOverlay() {
+	if (!_chtTitleOverlay || !_gfxScreen || !_gfxPalette16)
+		return;
+	if (_gfxScreen->getDisplayWidth() < _chtTitleOX + _chtTitleOW ||
+	    _gfxScreen->getDisplayHeight() < _chtTitleOY + _chtTitleOH)
+		return; // 非 upscaled(640x400) 或尺寸不符,不疊避免越界
+
+	// 內嵌調色盤 → 當前 palette 最近色索引(只在 used 色間找)
+	byte remap[256];
+	const Palette &sp = _gfxPalette16->_sysPalette;
+	for (int i = 0; i < _chtTitleNumColors; i++) {
+		int best = 1 << 30, bi = 0;
+		for (int j = 0; j < 256; j++) {
+			if (!sp.colors[j].used)
+				continue;
+			int dr = (int)sp.colors[j].r - _chtTitlePalR[i];
+			int dg = (int)sp.colors[j].g - _chtTitlePalG[i];
+			int db = (int)sp.colors[j].b - _chtTitlePalB[i];
+			int d = dr*dr + dg*dg + db*db;
+			if (d < best) { best = d; bi = j; }
+		}
+		remap[i] = (byte)bi;
+	}
+
+	for (uint16 ry = 0; ry < _chtTitleOH; ry++) {
+		const byte *src = _chtTitleOverlay + ry * _chtTitleOW;
+		for (uint16 rx = 0; rx < _chtTitleOW; rx++) {
+			byte v = src[rx];
+			if (v == 0xFF || v >= _chtTitleNumColors)
+				continue;
+			_gfxScreen->putPixelOnDisplay(_chtTitleOX + rx, _chtTitleOY + ry, remap[v]);
+		}
+	}
+	_gfxScreen->copyToScreen();
+	_chtTitleDrawn = true;
+}
+
 Common::Language SciEngine::getLanguage() const {
+	// Traditional Chinese fan translation: allow forcing ZH_TWN via the target's
+	// "language" config key (e.g. --language=zh_TW) so the CHT patch can be applied
+	// on top of the original English game without a dedicated detection entry.
+	if (ConfMan.hasKey("language")) {
+		if (Common::parseLanguage(ConfMan.get("language")) == Common::ZH_TWN)
+			return Common::ZH_TWN;
+	}
 	return _gameDescription->language;
 }
 
